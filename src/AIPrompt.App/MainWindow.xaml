<Window x:Class="AIPrompt.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:materialIcons="clr-namespace:Material.Icons.WPF;assembly=Material.Icons.WPF"
        xmlns:viewModels="clr-namespace:AIPrompt.App.ViewModels"
        mc:Ignorable="d"
        Title="AIPrompt" Height="720" Width="1200"
        FontFamily="{materialDesign:MaterialDesignFont}"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        Background="{DynamicResource MaterialDesignPaper}"
        d:DataContext="{d:DesignInstance Type=viewModels:MainViewModel}">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <materialDesign:ColorZone Grid.Column="0" Mode="PrimaryDark">
            <DockPanel LastChildFill="True">
                <StackPanel DockPanel.Dock="Top" Margin="16">
                    <TextBlock Text="AIPrompt" Style="{StaticResource MaterialDesignHeadline6TextBlock}" />
                </StackPanel>

                <ListBox ItemsSource="{Binding NavigationItems}"
                         SelectedItem="{Binding SelectedNavigationItem}"
                         Background="Transparent"
                         BorderThickness="0">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Margin="8">
                                <materialIcons:MaterialIcon Kind="{Binding Icon}" Width="20" Height="20" VerticalAlignment="Center" />
                                <TextBlock Text="{Binding Title}" Margin="12,0,0,0" VerticalAlignment="Center" />
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </materialDesign:ColorZone>

        <ContentControl Grid.Column="1"
                         Margin="0"
                         Content="{Binding SelectedNavigationItem.ViewModel}" />
    </Grid>
</Window>
