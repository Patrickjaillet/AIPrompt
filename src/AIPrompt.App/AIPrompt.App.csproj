      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
    <Resource Include="..\..\assets\icons\aiprompt-logo.png">
      <Link>Resources\aiprompt-logo.png</Link>
    </Resource>
  </ItemGroup>

