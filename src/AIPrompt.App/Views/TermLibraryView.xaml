<UserControl x:Class="AIPrompt.App.Views.TermLibraryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:viewModels="clr-namespace:AIPrompt.App.ViewModels"
             xmlns:services="clr-namespace:AIPrompt.App.Services"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=viewModels:TermLibraryViewModel}">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="{Binding [TermLibrary_Title], Source={x:Static services:Loc.Instance}}"
                   Style="{StaticResource MaterialDesignHeadline5TextBlock}"
                   Margin="0,0,0,16" />

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,16">
            <TextBox materialDesign:HintAssist.Hint="{Binding [Common_Search], Source={x:Static services:Loc.Instance}}"
                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                     Width="220"
                     Margin="0,0,16,0" />
            <ComboBox ItemsSource="{Binding CategoryFilters}"
                      SelectedItem="{Binding SelectedCategoryFilter}"
                      materialDesign:HintAssist.Hint="{Binding [Common_Category], Source={x:Static services:Loc.Instance}}"
                      Width="160"
                      Margin="0,0,16,0" />
            <ComboBox ItemsSource="{Binding GenreFilters}"
                      SelectedItem="{Binding SelectedGenreFilter}"
                      materialDesign:HintAssist.Hint="{Binding [Common_Genre], Source={x:Static services:Loc.Instance}}"
                      Width="160"
                      Margin="0,0,16,0" />
            <ComboBox ItemsSource="{Binding LanguageFilters}"
                      SelectedItem="{Binding SelectedLanguageFilter}"
                      materialDesign:HintAssist.Hint="{Binding [Common_Language], Source={x:Static services:Loc.Instance}}"
                      Width="100"
                      Margin="0,0,16,0" />
            <Button Content="{Binding [TermLibrary_AddTerm], Source={x:Static services:Loc.Instance}}"
                    Style="{StaticResource MaterialDesignRaisedButton}"
                    Command="{Binding AddTermCommand}"
                    Margin="0,0,8,0" />
            <Button Content="{Binding [TermLibrary_Categories], Source={x:Static services:Loc.Instance}}"
                    Style="{StaticResource MaterialDesignFlatButton}"
                    Command="{Binding ManageCategoriesCommand}"
                    Margin="0,0,8,0" />
            <Button Content="{Binding [TermLibrary_Genres], Source={x:Static services:Loc.Instance}}"
                    Style="{StaticResource MaterialDesignFlatButton}"
                    Command="{Binding ManageGenresCommand}" />
        </StackPanel>

        <DataGrid Grid.Row="2"
                  ItemsSource="{Binding Terms}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="{Binding [TermLibrary_ColumnContent], Source={x:Static services:Loc.Instance}}" Binding="{Binding Content}" Width="3*" />
                <DataGridTextColumn Header="{Binding [Common_Category], Source={x:Static services:Loc.Instance}}" Binding="{Binding CategoryName}" Width="*" />
                <DataGridTextColumn Header="{Binding [Common_Genre], Source={x:Static services:Loc.Instance}}" Binding="{Binding GenreName}" Width="*" />
                <DataGridTextColumn Header="{Binding [TermLibrary_ColumnTags], Source={x:Static services:Loc.Instance}}" Binding="{Binding Tags}" Width="2*" />
                <DataGridTextColumn Header="{Binding [Common_Language], Source={x:Static services:Loc.Instance}}" Binding="{Binding Language}" Width="Auto" />
                <DataGridTextColumn Header="{Binding [TermLibrary_ColumnUsages], Source={x:Static services:Loc.Instance}}" Binding="{Binding UsageCount}" Width="Auto" />
                <DataGridTemplateColumn Header="{Binding [Common_Actions], Source={x:Static services:Loc.Instance}}" Width="220">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <Button Content="{Binding [Common_Use], Source={x:Static services:Loc.Instance}}"
                                        Style="{StaticResource MaterialDesignFlatButton}"
                                        Command="{Binding DataContext.MarkUsedCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        CommandParameter="{Binding}" />
                                <Button Content="{Binding [Common_Edit], Source={x:Static services:Loc.Instance}}"
                                        Style="{StaticResource MaterialDesignFlatButton}"
                                        Command="{Binding DataContext.EditTermCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        CommandParameter="{Binding}" />
                                <Button Content="{Binding [Common_Delete], Source={x:Static services:Loc.Instance}}"
                                        Style="{StaticResource MaterialDesignFlatButton}"
                                        Command="{Binding DataContext.DeleteTermCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        CommandParameter="{Binding}" />
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
