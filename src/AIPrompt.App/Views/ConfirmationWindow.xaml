<Window x:Class="AIPrompt.App.Views.ConfirmationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:services="clr-namespace:AIPrompt.App.Services"
        x:Name="Root"
        Width="420" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        FontFamily="{materialDesign:MaterialDesignFont}"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        Background="{DynamicResource MaterialDesignPaper}">
    <StackPanel Margin="24">
        <TextBlock x:Name="TitleTextBlock" Style="{StaticResource MaterialDesignHeadline6TextBlock}" Margin="0,0,0,12" />
        <TextBlock x:Name="MessageTextBlock" TextWrapping="Wrap" Margin="0,0,0,24" />
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="{Binding [Common_Cancel], Source={x:Static services:Loc.Instance}}"
                    Style="{StaticResource MaterialDesignFlatButton}"
                    Click="OnCancelClick"
                    Margin="0,0,8,0" />
            <Button Content="{Binding [Common_Confirm], Source={x:Static services:Loc.Instance}}"
                    Style="{StaticResource MaterialDesignRaisedButton}"
                    Click="OnConfirmClick" />
        </StackPanel>
    </StackPanel>
</Window>
