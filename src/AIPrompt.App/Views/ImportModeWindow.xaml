<Window x:Class="AIPrompt.App.Views.ImportModeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:services="clr-namespace:AIPrompt.App.Services"
        x:Name="Root"
        Title="{Binding [ImportMode_Title], Source={x:Static services:Loc.Instance}}"
        Width="440" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        FontFamily="{materialDesign:MaterialDesignFont}"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        Background="{DynamicResource MaterialDesignPaper}">
    <StackPanel Margin="24">
        <TextBlock Text="{Binding [ImportMode_Question], Source={x:Static services:Loc.Instance}}" Style="{StaticResource MaterialDesignHeadline6TextBlock}" Margin="0,0,0,12" />
        <TextBlock TextWrapping="Wrap" Margin="0,0,0,24">
            <Run Text="{Binding [ImportMode_MergeExplanation], Source={x:Static services:Loc.Instance}, Mode=OneWay}" /><LineBreak />
            <Run Text="{Binding [ImportMode_OverwriteExplanation], Source={x:Static services:Loc.Instance}, Mode=OneWay}" />
        </TextBlock>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="{Binding [Common_Cancel], Source={x:Static services:Loc.Instance}}"
                    Style="{StaticResource MaterialDesignFlatButton}"
                    Click="OnCancelClick"
                    Margin="0,0,8,0" />
            <Button Content="{Binding [ImportMode_Merge], Source={x:Static services:Loc.Instance}}"
                    Style="{StaticResource MaterialDesignFlatButton}"
                    Click="OnMergeClick"
                    Margin="0,0,8,0" />
            <Button Content="{Binding [ImportMode_Overwrite], Source={x:Static services:Loc.Instance}}"
                    Style="{StaticResource MaterialDesignRaisedButton}"
                    Click="OnOverwriteClick" />
        </StackPanel>
    </StackPanel>
</Window>
