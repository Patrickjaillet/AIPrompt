<UserControl x:Class="AIPrompt.App.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:viewModels="clr-namespace:AIPrompt.App.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=viewModels:SettingsViewModel}">
    <Grid Margin="24">
        <StackPanel>
            <TextBlock Text="Paramètres"
                       Style="{StaticResource MaterialDesignHeadline5TextBlock}"
                       Margin="0,0,0,24" />

            <TextBlock Text="Thème" Style="{StaticResource MaterialDesignSubtitle1TextBlock}" Margin="0,0,0,8" />
            <ComboBox ItemsSource="{Binding ThemeModes}"
                      SelectedItem="{Binding SelectedThemeMode}"
                      Width="200"
                      HorizontalAlignment="Left"
                      Margin="0,0,0,24" />

            <TextBlock Text="Couleur d'accent" Style="{StaticResource MaterialDesignSubtitle1TextBlock}" Margin="0,0,0,8" />
            <ComboBox ItemsSource="{Binding AccentColors}"
                      SelectedItem="{Binding SelectedAccentColor}"
                      Width="200"
                      HorizontalAlignment="Left"
                      Margin="0,0,0,24" />

            <TextBlock Text="Langue de l'interface" Style="{StaticResource MaterialDesignSubtitle1TextBlock}" Margin="0,0,0,8" />
            <ComboBox ItemsSource="{Binding Languages}"
                      SelectedItem="{Binding SelectedLanguage}"
                      Width="200"
                      HorizontalAlignment="Left" />
            <TextBlock Text="{Binding LanguageNotice}" Foreground="{DynamicResource MaterialDesignBodyLight}" Margin="0,4,0,24" />

            <TextBlock Text="Dossier d'export par défaut (prompts)" Style="{StaticResource MaterialDesignSubtitle1TextBlock}" Margin="0,0,0,8" />
            <StackPanel Orientation="Horizontal" Margin="0,0,0,24">
                <TextBox Text="{Binding DefaultExportFolder, Mode=OneWay}"
                         IsReadOnly="True"
                         Width="360"
                         Margin="0,0,8,0" />
                <Button Content="PARCOURIR"
                        Style="{StaticResource MaterialDesignFlatButton}"
                        Command="{Binding BrowseExportFolderCommand}" />
            </StackPanel>

            <TextBlock Text="Dossier d'export par défaut (roadmaps)" Style="{StaticResource MaterialDesignSubtitle1TextBlock}" Margin="0,0,0,8" />
            <StackPanel Orientation="Horizontal" Margin="0,0,0,24">
                <TextBox Text="{Binding DefaultRoadmapExportFolder, Mode=OneWay}"
                         IsReadOnly="True"
                         Width="360"
                         Margin="0,0,8,0" />
                <Button Content="PARCOURIR"
                        Style="{StaticResource MaterialDesignFlatButton}"
                        Command="{Binding BrowseRoadmapExportFolderCommand}" />
            </StackPanel>

            <TextBlock Text="Dossier de sauvegarde" Style="{StaticResource MaterialDesignSubtitle1TextBlock}" Margin="0,0,0,8" />
            <StackPanel Orientation="Horizontal" Margin="0,0,0,24">
                <TextBox Text="{Binding DefaultBackupFolder, Mode=OneWay}"
                         IsReadOnly="True"
                         Width="360"
                         Margin="0,0,8,0" />
                <Button Content="PARCOURIR"
                        Style="{StaticResource MaterialDesignFlatButton}"
                        Command="{Binding BrowseBackupFolderCommand}" />
            </StackPanel>

            <TextBlock Text="Zone de danger" Style="{StaticResource MaterialDesignSubtitle1TextBlock}" Margin="0,0,0,8" />
            <Button Content="RÉINITIALISER LA BASE DE DONNÉES"
                    Style="{StaticResource MaterialDesignRaisedButton}"
                    Command="{Binding ResetDatabaseCommand}"
                    HorizontalAlignment="Left" />
        </StackPanel>
    </Grid>
</UserControl>
