<UserControl x:Class="AIPrompt.App.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:viewModels="clr-namespace:AIPrompt.App.ViewModels"
             xmlns:services="clr-namespace:AIPrompt.App.Services"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=viewModels:SettingsViewModel}">
    <Grid Margin="24">
        <StackPanel>
            <TextBlock Text="{Binding [SettingsTitle], Source={x:Static services:Loc.Instance}}"
                       Style="{StaticResource MaterialDesignHeadline5TextBlock}"
                       Margin="0,0,0,24" />

            <TextBlock Text="{Binding [ThemeLabel], Source={x:Static services:Loc.Instance}}" Style="{StaticResource MaterialDesignSubtitle1TextBlock}" Margin="0,0,0,8" />
            <ComboBox ItemsSource="{Binding ThemeModes}"
                      SelectedItem="{Binding SelectedThemeMode}"
                      IsSynchronizedWithCurrentItem="False"
                      Width="200"
                      HorizontalAlignment="Left"
                      Margin="0,0,0,24" />

            <TextBlock Text="{Binding [AccentColorLabel], Source={x:Static services:Loc.Instance}}" Style="{StaticResource MaterialDesignSubtitle1TextBlock}" Margin="0,0,0,8" />
            <ComboBox ItemsSource="{Binding AccentColors}"
                      SelectedItem="{Binding SelectedAccentColor}"
                      IsSynchronizedWithCurrentItem="False"
                      Width="200"
                      HorizontalAlignment="Left"
                      Margin="0,0,0,24" />

            <TextBlock Text="{Binding [LanguageLabel], Source={x:Static services:Loc.Instance}}" Style="{StaticResource MaterialDesignSubtitle1TextBlock}" Margin="0,0,0,8" />
            <ComboBox ItemsSource="{Binding Languages}"
                      SelectedItem="{Binding SelectedLanguage}"
                      IsSynchronizedWithCurrentItem="False"
                      Width="200"
                      HorizontalAlignment="Left" />
            <TextBlock Text="{Binding LanguageNotice}" Foreground="{DynamicResource MaterialDesignBodyLight}" Margin="0,4,0,24" />

            <TextBlock Text="{Binding [DefaultExportFolderLabel], Source={x:Static services:Loc.Instance}}" Style="{StaticResource MaterialDesignSubtitle1TextBlock}" Margin="0,0,0,8" />
            <StackPanel Orientation="Horizontal" Margin="0,0,0,24">
                <TextBox Text="{Binding DefaultExportFolder, Mode=OneWay}"
                         IsReadOnly="True"
                         Width="360"
                         Margin="0,0,8,0" />
                <Button Content="{Binding [Settings_Browse], Source={x:Static services:Loc.Instance}}"
                        Style="{StaticResource MaterialDesignFlatButton}"
                        Command="{Binding BrowseExportFolderCommand}" />
            </StackPanel>

            <TextBlock Text="{Binding [DefaultRoadmapExportFolderLabel], Source={x:Static services:Loc.Instance}}" Style="{StaticResource MaterialDesignSubtitle1TextBlock}" Margin="0,0,0,8" />
            <StackPanel Orientation="Horizontal" Margin="0,0,0,24">
                <TextBox Text="{Binding DefaultRoadmapExportFolder, Mode=OneWay}"
                         IsReadOnly="True"
                         Width="360"
                         Margin="0,0,8,0" />
                <Button Content="{Binding [Settings_Browse], Source={x:Static services:Loc.Instance}}"
                        Style="{StaticResource MaterialDesignFlatButton}"
                        Command="{Binding BrowseRoadmapExportFolderCommand}" />
            </StackPanel>

            <TextBlock Text="{Binding [DefaultBackupFolderLabel], Source={x:Static services:Loc.Instance}}" Style="{StaticResource MaterialDesignSubtitle1TextBlock}" Margin="0,0,0,8" />
            <StackPanel Orientation="Horizontal" Margin="0,0,0,24">
                <TextBox Text="{Binding DefaultBackupFolder, Mode=OneWay}"
                         IsReadOnly="True"
                         Width="360"
                         Margin="0,0,8,0" />
                <Button Content="{Binding [Settings_Browse], Source={x:Static services:Loc.Instance}}"
                        Style="{StaticResource MaterialDesignFlatButton}"
                        Command="{Binding BrowseBackupFolderCommand}" />
            </StackPanel>

            <TextBlock Text="{Binding [Settings_DangerZone], Source={x:Static services:Loc.Instance}}" Style="{StaticResource MaterialDesignSubtitle1TextBlock}" Margin="0,0,0,8" />
            <Button Content="{Binding [ResetDatabaseLabel], Source={x:Static services:Loc.Instance}}"
                    Style="{StaticResource MaterialDesignRaisedButton}"
                    Command="{Binding ResetDatabaseCommand}"
                    HorizontalAlignment="Left" />
        </StackPanel>
    </Grid>
</UserControl>
